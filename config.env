# ═══════════════════════════════════════════════════════════════════════════════
#  config.env  —  MASTER CONFIGURATION FILE
#  Edit ONLY this file to make the entire setup work with YOUR infrastructure.
#  All other files read from here automatically.
# ═══════════════════════════════════════════════════════════════════════════════

# ── AWS Settings ───────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1                          # Your AWS region
BEDROCK_REGION=ap-south-1                      # Bedrock region (same or us-east-1)

# ── Bedrock Model ──────────────────────────────────────────────────────────────
# Pick ONE based on your region:
#   ap-south-1, ap-southeast-1, ap-northeast-1  → apac.anthropic.claude-3-5-sonnet-20241022-v2:0
#   us-east-1, us-east-2, us-west-2             → us.anthropic.claude-3-5-sonnet-20241022-v2:0
#   eu-west-1, eu-central-1                     → eu.anthropic.claude-3-5-sonnet-20241022-v2:0
#
# Cheaper alternative (10x lower cost, still great):
#   apac.anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_MODEL_ID=apac.anthropic.claude-3-haiku-20240307-v1:0
EXTERNAL_API_URL=https://api.ai.kodekloud.com/v1
EXTERNAL_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXX

# ── Project Naming ─────────────────────────────────────────────────────────────
PROJECT_NAME=tf-analyzer                       # Used in all resource names
ENVIRONMENT=dev                                # dev / staging / prod

# ── Alerts ────────────────────────────────────────────────────────────────────
ALERT_EMAIL=your-email@gmail.com              # Gmail or any email for HIGH risk alerts

# ── Lambda Settings ────────────────────────────────────────────────────────────
LAMBDA_TIMEOUT=120                             # seconds (increase if timeouts occur)
LAMBDA_MEMORY=256                              # MB (128 is fine too, saves cost)
MAX_TOKENS=2048                               # Bedrock response length

# ── Cost Control ───────────────────────────────────────────────────────────────
LOG_RETENTION_DAYS=7                           # CloudWatch log retention (7 = free tier friendly)

# ── YOUR Terraform Project ─────────────────────────────────────────────────────
# Point this to the Terraform directory you want to analyze
# Used by scripts/analyze.sh when running locally or in CI
YOUR_TF_DIR=../terraform          # Relative or absolute path

# ── Jenkins Settings (only needed if using Jenkins) ────────────────────────────
JENKINS_CREDENTIALS_ID=aws-credentials        # Jenkins credential ID for AWS
JENKINS_APPROVAL_USERS=admin,devops     # Who can approve HIGH risk plans
JENKINS_APPROVAL_TIMEOUT_HOURS=24             # How long to wait for human approval
